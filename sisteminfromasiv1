  <!-- SCRIPT LOGIKA -->
  <script>
    // Inisialisasi Icons
    lucide.createIcons();

    // URL untuk Mengambil Data (Siswa & Ekskul) - Spreadsheet 1
    const GAS_URL_GET = "https://script.google.com/macros/s/AKfycbyNBWIlBPWbpVx2zSA73Vkhn8fmHyiTS2Dpcy-tFwiyjiSBp2ykBbOm0wLoH_MPVUQsGg/exec";
    
    // URL untuk Mengirim Data (Pendaftaran) - Spreadsheet 2
    const GAS_URL_POST = "https://script.google.com/macros/s/AKfycbyJb0NKDECWU8RVAmqCedvMUXmhgSsLXeLJG_pZQyi7OR8ihlJoGweQO6sLT5EbYySR/exec";

    // Variables / State
    let siswaData = [];
    let ekskulData = [];
    let isDataLoaded = false;
    let selectedFile = null;
    let isPaymentRequiredForSelected = false;

    // DOM Elements
    const viewHome = document.getElementById('view-home');
    const viewRegister = document.getElementById('view-register');
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    
    // Form Elements
    const loadingState = document.getElementById('loading-state');
    const registerForm = document.getElementById('register-form');
    const kelasSelect = document.getElementById('kelas-select');
    const siswaSelect = document.getElementById('siswa-select');
    const kelasWarning = document.getElementById('kelas-warning');
    const ekskulSelect = document.getElementById('ekskul-select');
    
    // Payment Elements
    const paymentSection = document.getElementById('payment-section');
    const paymentRequiredBox = document.getElementById('payment-required-box');
    const paymentFreeBox = document.getElementById('payment-free-box');
    const paymentAmountText = document.getElementById('payment-amount');
    const buktiTfInput = document.getElementById('bukti-tf');
    const fileNameDisplay = document.getElementById('file-name-display');
    const fileHelperText = document.getElementById('file-helper-text');
    
    // Ekskul Elements
    const ekskulGrid = document.getElementById('ekskul-grid');
    const ekskulLoading = document.getElementById('ekskul-loading');

    // Generate Dummy Images
    const dokGrid = document.getElementById('dokumentasi-grid');
    for(let i=0; i<8; i++) {
      dokGrid.innerHTML += `
        <div class="aspect-square bg-gray-200 rounded-lg overflow-hidden group relative">
          <div class="w-full h-full flex items-center justify-center bg-gray-300">
            <i data-lucide="image" class="w-10 h-10 text-gray-400"></i>
          </div>
          <div class="absolute inset-0 bg-blue-900 bg-opacity-0 group-hover:bg-opacity-60 transition-all duration-300 flex items-center justify-center">
            <span class="text-white opacity-0 group-hover:opacity-100 font-semibold">Lihat Foto</span>
          </div>
        </div>
      `;
    }
    lucide.createIcons();

    // Toggle Mobile Menu
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });

    // Navigasi Antar Halaman
    function navigateTo(view) {
      if(view === 'home') {
        viewHome.classList.remove('hidden');
        viewRegister.classList.add('hidden');
      } else if (view === 'register') {
        viewHome.classList.add('hidden');
        viewRegister.classList.remove('hidden');
      }
      mobileMenu.classList.add('hidden');
      window.scrollTo(0, 0);
    }

    // Tampilkan Pesan Status
    function showStatus(type, message) {
      const alertBox = document.getElementById('status-alert');
      const icon = document.getElementById('status-icon');
      const text = document.getElementById('status-text');
      
      alertBox.className = 'p-4 rounded-lg mb-6 flex items-start gap-3 shadow-sm';
      text.innerText = message;
      
      if(type === 'error') {
        alertBox.classList.add('bg-red-50', 'text-red-800', 'border', 'border-red-200');
        icon.setAttribute('data-lucide', 'alert-circle');
      } else if (type === 'info') {
        alertBox.classList.add('bg-blue-50', 'text-blue-800', 'border', 'border-blue-200');
        icon.setAttribute('data-lucide', 'loader-2');
        icon.classList.add('animate-spin');
      } else {
        alertBox.classList.add('bg-green-50', 'text-green-800', 'border', 'border-green-200');
        icon.setAttribute('data-lucide', 'check-circle-2');
      }
      
      alertBox.classList.remove('hidden');
      lucide.createIcons();
    }

    // Sembunyikan Pesan Status
    function hideStatus() {
      document.getElementById('status-alert').classList.add('hidden');
      document.getElementById('status-icon').classList.remove('animate-spin');
    }

    // Panggil fetchData() di awal saat halaman pertama kali di-load
    window.addEventListener('DOMContentLoaded', () => {
      fetchData();
    });

    // Fetch Data API
    async function fetchData() {
      try {
        const resSiswa = await fetch(GAS_URL_GET + "?action=getSiswa");
        const dataSiswa = await resSiswa.json();
        
        const resEkskul = await fetch(GAS_URL_GET + "?action=getEkskul");
        const dataEkskul = await resEkskul.json();

        if(dataSiswa.length > 0) siswaData = dataSiswa;
        if(dataEkskul.length > 0) ekskulData = dataEkskul;
      } catch (error) {
        console.error("Gagal mengambil data, menggunakan Data Dummy Ekskul Lengkap", error);
        
        // Fallback data siswa
        siswaData = [
          { kelas: '7 AE 1', nama: 'Ahmad Budi (Data Dummy)' },
          { kelas: '7 AE 1', nama: 'Siti Aminah (Data Dummy)' },
          { kelas: '7 AE 2', nama: 'Bagus Sajiwo (Data Dummy)' }
        ];
        
        // Fallback Data Ekskul Lengkap (Sesuai Permintaan)
        ekskulData = [
          { nama_ekskul: 'Tahfiz Al Qur\'an', biaya_daftar: 0, biaya_bulanan: 0 },
          { nama_ekskul: 'Arabic Club', biaya_daftar: 0, biaya_bulanan: 0 },
          { nama_ekskul: 'Basket', biaya_daftar: 50000, biaya_bulanan: 25000 },
          { nama_ekskul: 'Futsal', biaya_daftar: 50000, biaya_bulanan: 25000 },
          { nama_ekskul: 'Copywriter', biaya_daftar: 0, biaya_bulanan: 0 },
          { nama_ekskul: 'English Club', biaya_daftar: 0, biaya_bulanan: 0 },
          { nama_ekskul: 'Handcrafting', biaya_daftar: 0, biaya_bulanan: 0 },
          { nama_ekskul: 'Karate', biaya_daftar: 50000, biaya_bulanan: 25000 },
          { nama_ekskul: 'Math Club', biaya_daftar: 0, biaya_bulanan: 0 },
          { nama_ekskul: 'Nagham', biaya_daftar: 0, biaya_bulanan: 0 },
          { nama_ekskul: 'Panahan', biaya_daftar: 75000, biaya_bulanan: 50000 },
          { nama_ekskul: 'Robotic', biaya_daftar: 100000, biaya_bulanan: 75000 },
          { nama_ekskul: 'Science Club', biaya_daftar: 0, biaya_bulanan: 0 }
        ];
      } finally {
        populateKelas();
        populateEkskul();
        renderEkskulCards();
        isDataLoaded = true;
        
        // Hide loading states
        loadingState.classList.add('hidden');
        ekskulLoading.classList.add('hidden');
        
        // Show components
        registerForm.classList.remove('hidden');
        ekskulGrid.classList.remove('hidden');
      }
    }

    // SISTEM PENDETEKSI IKON (MENGGUNAKAN EMOJI BERWARNA)
    function getEkskulIcon(nama) {
      const n = nama.toLowerCase();
      
      // Ikon Spesifik Sesuai Permintaan
      if (n.includes("qur'an") || n.includes('tahfiz') || n.includes('quran')) return '📖';
      if (n.includes('arabic') || n.includes('arab')) return '🇸🇦';
      if (n.includes('basket')) return '🏀';
      if (n.includes('futsal') || n.includes('sepak bola') || n.includes('gawang')) return '🥅';
      if (n.includes('copywriter') || n.includes('nulis') || n.includes('laptop')) return '💻';
      if (n.includes('english') || n.includes('inggris')) return '🇬🇧';
      if (n.includes('handcrafting') || n.includes('karya') || n.includes('kerajinan') || n.includes('pita')) return '🎀';
      if (n.includes('karate') || n.includes('silat') || n.includes('bela diri') || n.includes('perisai')) return '🛡️';
      if (n.includes('math') || n.includes('matematika') || n.includes('hitung')) return '🧮';
      if (n.includes('nagham') || n.includes('masjid')) return '🕌';
      if (n.includes('panahan') || n.includes('memanah') || n.includes('busur')) return '🏹';
      if (n.includes('robotic') || n.includes('robot')) return '🤖';
      if (n.includes('science') || n.includes('sains') || n.includes('ipa') || n.includes('mikroskop')) return '🔬';

      // Ekstra Ikon untuk yang mungkin ada di kemudian hari
      if (n.includes('pramuka')) return '🏕️';
      if (n.includes('paskibra')) return '🇮🇩';
      if (n.includes('pmr') || n.includes('kesehatan')) return '🩺';
      if (n.includes('tari') || n.includes('seni')) return '🎭';
      if (n.includes('voli')) return '🏐';
      
      return '✨'; // Default icon jika belum terdeteksi
    }

    // Render Kartu Ekstrakurikuler di Halaman Home dengan Ikon Emoji 3D
    function renderEkskulCards() {
      ekskulGrid.innerHTML = '';
      if(ekskulData.length === 0) {
        ekskulGrid.innerHTML = '<p class="text-slate-500 col-span-full text-center">Belum ada data ekstrakurikuler.</p>';
        return;
      }
      
      ekskulData.forEach(eks => {
        const emojiIcon = getEkskulIcon(eks.nama_ekskul);
        ekskulGrid.innerHTML += `
          <div class="group bg-white rounded-xl overflow-hidden shadow-md border border-slate-100 hover:shadow-xl transition-shadow duration-300">
            <div class="h-32 bg-gradient-to-br from-blue-50 to-blue-100 flex items-center justify-center overflow-hidden">
              <span class="text-6xl drop-shadow-md transform transition-transform duration-300 group-hover:scale-125 group-hover:-rotate-3">
                ${emojiIcon}
              </span>
            </div>
            <div class="p-5">
              <h3 class="font-bold text-xl text-blue-900 mb-2">${eks.nama_ekskul}</h3>
              <p class="text-gray-600 text-sm mb-4">Kegiatan pengembangan diri bidang ${eks.nama_ekskul.toLowerCase()} untuk siswa.</p>
              <button onclick="navigateTo('register')" class="text-blue-700 font-semibold hover:text-amber-500 text-sm flex items-center gap-1">
                Daftar ekskul ini <i data-lucide="chevron-right" class="w-4 h-4"></i>
              </button>
            </div>
          </div>
        `;
      });
      lucide.createIcons(); // Re-render Lucide icons (chevron-right) yang baru ditambahkan
    }

    // Isi Dropdown Kelas
    function populateKelas() {
      const kelasUnik = [...new Set(siswaData.map(item => item.kelas))];
      kelasSelect.innerHTML = '<option value="" disabled selected>-- Pilih Kelas --</option>';
      kelasUnik.forEach(k => {
        kelasSelect.innerHTML += `<option value="${k}">${k}</option>`;
      });
    }

    // Isi Dropdown Ekstrakurikuler
    function populateEkskul() {
      ekskulSelect.innerHTML = '<option value="" disabled selected>-- Pilih Ekstrakurikuler --</option>';
      ekskulData.forEach(e => {
        ekskulSelect.innerHTML += `<option value="${e.nama_ekskul}">${e.nama_ekskul}</option>`;
      });
    }

    // Event Listener: Kelas Berubah
    kelasSelect.addEventListener('change', (e) => {
      const kelas = e.target.value;
      siswaSelect.innerHTML = '<option value="" disabled selected>-- Pilih Siswa --</option>';
      
      const filteredSiswa = siswaData.filter(item => item.kelas === kelas);
      filteredSiswa.forEach(s => {
        siswaSelect.innerHTML += `<option value="${s.nama}">${s.nama}</option>`;
      });
      
      siswaSelect.disabled = false;
      kelasWarning.classList.add('hidden');
    });

    // Event Listener: Ekskul Berubah
    ekskulSelect.addEventListener('change', (e) => {
      const eksName = e.target.value;
      const details = ekskulData.find(eks => eks.nama_ekskul === eksName);
      
      if(details) {
        paymentSection.classList.remove('hidden');
        const biaya = Number(details.biaya_daftar);
        
        if(biaya > 0) {
          isPaymentRequiredForSelected = true;
          paymentRequiredBox.classList.remove('hidden');
          paymentFreeBox.classList.add('hidden');
          paymentAmountText.innerText = `Rp ${biaya.toLocaleString('id-ID')}`;
        } else {
          isPaymentRequiredForSelected = false;
          paymentRequiredBox.classList.add('hidden');
          paymentFreeBox.classList.remove('hidden');
        }
      }
    });

    // Event Listener: File Upload
    buktiTfInput.addEventListener('change', (e) => {
      if(e.target.files.length > 0) {
        selectedFile = e.target.files[0];
        fileNameDisplay.innerText = selectedFile.name;
        fileHelperText.classList.add('hidden');
      } else {
        selectedFile = null;
        fileNameDisplay.innerText = "Klik atau drop file di sini";
        fileHelperText.classList.remove('hidden');
      }
    });

    // Konversi File ke Base64
    function getBase64(file) {
      return new Promise((resolve, reject) => {
        if (!file) resolve(null);
        const reader = new FileReader();
        reader.readAsDataURL(file);
        reader.onload = () => resolve(reader.result.split(',')[1]);
        reader.onerror = error => reject(error);
      });
    }

    // Submit Pendaftaran
    registerForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Validasi URL sudah diubah atau belum
      if (GAS_URL_POST === "MASUKKAN_URL_APPSCRIPT_PENDAFTARAN_DI_SINI") {
         showStatus('error', 'DEVELOPER ERROR: Tolong ubah URL GAS_URL_POST di dalam kodenya dengan URL AppScript yang baru!');
         window.scrollTo(0, 0);
         return;
      }
      
      if(isPaymentRequiredForSelected && !selectedFile) {
        showStatus('error', 'Mohon upload bukti transfer pendaftaran terlebih dahulu.');
        window.scrollTo(0, 0);
        return;
      }

      showStatus('info', 'Sedang mengirim data pendaftaran ke server...');
      window.scrollTo(0, 0);

      try {
        const fileBase64 = selectedFile ? await getBase64(selectedFile) : "";
        const fileName = selectedFile ? selectedFile.name : "";
        const mimeType = selectedFile ? selectedFile.type : "";

        const payload = {
          action: "register",
          kelas: kelasSelect.value,
          nama_siswa: siswaSelect.value,
          no_wa: document.getElementById('no-wa').value,
          password: document.getElementById('password').value,
          ekskul: ekskulSelect.value,
          fileBase64: fileBase64,
          fileName: fileName,
          mimeType: mimeType
        };

        await fetch(GAS_URL_POST, {
          method: "POST",
          mode: "no-cors",
          headers: {
            "Content-Type": "text/plain",
          },
          body: JSON.stringify(payload)
        });

        showStatus('success', 'Jazaakumullahu khairan telah mendaftar. Anda akan dialihkan ke halaman utama...');
        
        // Reset and Redirect
        setTimeout(() => {
          registerForm.reset();
          siswaSelect.disabled = true;
          kelasWarning.classList.remove('hidden');
          paymentSection.classList.add('hidden');
          selectedFile = null;
          fileNameDisplay.innerText = "Klik atau drop file di sini";
          fileHelperText.classList.remove('hidden');
          hideStatus();
          navigateTo('home');
        }, 3000);

      } catch (error) {
        showStatus('error', 'Gagal mengirim data. Pastikan jaringan stabil. Error: ' + error.message);
      }
    });

  </script>
</body>
